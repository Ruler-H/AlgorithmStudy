    "# 백준 22155번 - Простая задача\n",
    "import sys\n",
    "# input = sys.stdin.readline\n",
    "\n",
    "n = int(input())\n",
    "\n",
    "for _ in range(n):\n",
    "    i, f = map(int, input().split())\n",
    "    if (i <= 1 and f <= 2) or (i <= 2 and f <= 1):\n",
    "        print(\"Yes\")\n",
    "    else:\n",
    "        print(\"No\")\n"
