    "# 백준 13236번 - Collatz Conjecture\n",
    "import sys\n",
    "# input = sys.stdin.readline\n",
    "\n",
    "n = int(input().strip())\n",
    "\n",
    "while True:\n",
    "    print(n)\n",
    "    if n == 1:\n",
    "        break\n",
    "    else:\n",
    "        if n % 2 == 0:\n",
    "            n //= 2\n",
    "        else:\n",
    "            n = (n * 3) + 1"
