   "source": [
    "# 백준 31831번 - 과민성 대장 증후군\n",
    "import sys\n",
    "# input = sys.stdin.readline\n",
    "\n",
    "N, M = map(int, input().split())\n",
    "A = list(map(int, input().split()))\n",
    "cnt = 0\n",
    "total = 0\n",
    "\n",
    "for i in A:\n",
    "    total += i\n",
    "    if total < 0:\n",
    "        total = 0\n",
    "    if total >= M:\n",
    "        cnt += 1\n",
    "\n",
    "print(cnt)"
   ]
