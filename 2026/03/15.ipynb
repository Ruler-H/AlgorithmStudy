    "# 백준 15995번 - 잉여역수 구하기\n",
    "import sys\n",
    "# input = sys.stdin.readline\n",
    "\n",
    "a, m = map(int, input().split())\n",
    "\n",
    "for x in range(1, m + 1):\n",
    "    if (a * x) % m == 1:\n",
    "        print(x)\n",
    "        break"
