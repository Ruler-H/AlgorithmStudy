   "source": "# 백준 31789번 - 모험의 시작\nimport sys\ninput = sys.stdin.readline\n\nN = int(input())\nX, S = map(int, input().split())\n\nresult = \"NO\"\nfor _ in range(N):\n    c, p = map(int, input().split())\n    if c <= X and p > S:\n        result = \"YES\"\n\nprint(result)"
  }
