   "source": [
    "# 백준 14471번 - 포인트 카드\n",
    "import sys\n",
    "input = sys.stdin.readline\n",
    "\n",
    "N, M = map(int, input().split())\n",
    "costs = []\n",
    "for _ in range(M):\n",
    "    A, B = map(int, input().split())\n",
    "    costs.append(max(0, N - A))\n",
    "\n",
    "costs.sort()\n",
    "# M-1개 이상이면 되므로, 가장 비용이 큰 카드 1장을 제외\n",
    "print(sum(costs[:M - 1]))"
   ]
  }
