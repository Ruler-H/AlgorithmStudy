   "source": [
    "# 백준 27590번 - Sun and Moon\n",
    "import sys\n",
    "# input = sys.stdin.readline\n",
    "\n",
    "ds, ys = map(int, input().split())\n",
    "dm, ym = map(int, input().split())\n",
    "\n",
    "ds = -ds\n",
    "dm = -dm\n",
    "\n",
    "while ds != dm:\n",
    "    if ds < dm:\n",
    "        ds += ys\n",
    "    else:\n",
    "        dm += ym\n",
    "\n",
    "print(ds)\n"
   ]
