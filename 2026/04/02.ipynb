    "# 백준 33541번 - 2025는 무엇이 특별할까?\n",
    "import sys\n",
    "# input = sys.stdin.readline\n",
    "\n",
    "X = int(input())\n",
    "\n",
    "for i in range(X + 1, 10000):\n",
    "    if (int(str(i)[:2]) + int(str(i)[2:])) ** 2 == i:\n",
    "        print(i)\n",
    "        break\n",
    "else:\n",
    "    print(-1)"
