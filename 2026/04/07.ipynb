    "# 백준 27267번 - Сравнение комнат\n",
    "import sys\n",
    "# input = sys.stdin.readline\n",
    "\n",
    "a, b, c, d = map(int, input().split())\n",
    "\n",
    "p = a * b\n",
    "q = c * d\n",
    "\n",
    "if p > q:\n",
    "    print(\"M\")\n",
    "elif p < q:\n",
    "    print(\"P\")\n",
    "else:\n",
    "    print(\"E\")"
   ]
