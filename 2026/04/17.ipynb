    "# 백준 18245번 - 이상한 나라의 암호\n",
    "import sys\n",
    "# input = sys.stdin.readline\n",
    "\n",
    "cnt = 1\n",
    "while True:\n",
    "    inp_str = input().strip()\n",
    "    if inp_str == \"Was it a cat I saw?\":\n",
    "        break\n",
    "    cnt += 1\n",
    "\n",
    "    for i in range(0, len(inp_str), cnt):\n",
    "        print(inp_str[i], end=\"\")\n",
    "    print()"
